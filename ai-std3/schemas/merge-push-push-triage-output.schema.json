{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "merge-push-push-triage-output.schema.json",
  "title": ".pipeline/merge-push-push-triage.json",
  "type": "object",
  "required": ["decision", "category", "reason"],
  "additionalProperties": false,
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["retry_push", "fix_rebase", "blocked"]
    },
    "category": {
      "type": "string",
      "enum": [
        "transient",
        "rebase_conflict",
        "credentials",
        "permissions",
        "branch_protection",
        "network",
        "unknown"
      ]
    },
    "reason": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files_touched": {
      "type": "array",
      "items": { "type": "string" }
    },
    "user_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
