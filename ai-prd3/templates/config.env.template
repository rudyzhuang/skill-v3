# docs/config.env 占位模板：只放变量名、空值和说明，不要放真实密钥。
#
# 本版（skill-v3）路径策略：
# 1. 唯一标准路径为 <project_root>/docs/config.env；ai-*3 不再读取上一版的 scripts/config.env，
#    也不会做回退兼容（参见 input-spec.md §9.2 与上一版边界声明）。
# 2. 在真实文件里填写代理、Token、云厂商凭据等值；本 template 文件保持空值并提交到 git。
# 3. 确认 docs/config.env 已加入 .gitignore，除非团队已有加密密钥入库流程。
#
# 配置分工：
# - 非敏感资源名、服务名、地域、域名、健康检查路径等，写到 docs/config.dev.json / docs/config.release.json。
# - 密钥、Token、访问凭据、数据库连接串、初始管理员密码等，只写到 docs/config.env 或批准的密钥管理系统。

# ---------------------------------------------------------------------------
# 代理配置
# ---------------------------------------------------------------------------
# HTTP/HTTPS 代理供 git、curl、node、npm、pip、云厂商 CLI 等命令使用。
# 常见格式：
# - 无账号密码：http://127.0.0.1:7890
# - 有账号密码：http://user:password@proxy.example.com:8080
# - socks 代理一般写成 socks5://127.0.0.1:1080，前提是调用工具支持 socks。
HTTP_PROXY=
HTTPS_PROXY=

# 不走代理的地址。通常保留 localhost / 127.0.0.1；内网域名、K8s 服务域名、云厂商内网 endpoint 可按需追加，用英文逗号分隔。
NO_PROXY=localhost,127.0.0.1

# 小写变量用于兼容部分 Linux 工具或旧脚本。建议和上面的值保持一致。
http_proxy=
https_proxy=
no_proxy=localhost,127.0.0.1

# npm / pip 镜像或代理。只有在安装依赖需要走特殊代理/镜像时填写。
# NPM_CONFIG_PROXY / NPM_CONFIG_HTTPS_PROXY 可直接复用 HTTP_PROXY / HTTPS_PROXY。
# PIP_INDEX_URL 可填企业 PyPI 或可信镜像地址；PIP_EXTRA_INDEX_URL 用于补充第二个源。
NPM_CONFIG_PROXY=
NPM_CONFIG_HTTPS_PROXY=
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=

# ---------------------------------------------------------------------------
# 通用项目与云厂商选择
# ---------------------------------------------------------------------------
# 当前选择的部署厂商，建议使用 deploy-services.catalog.json 里的 provider id。
# 例：cloudflare / vercel / aws / google_cloud / azure / tencent_cloud / alibaba_cloud / huawei_cloud / oci / manual。
CLOUD_PROVIDER=

# 通用账号、项目、地域字段。脚本如果不区分厂商，可以读取这些变量；厂商专用脚本优先读取下面的专用变量。
# 这些值通常在云控制台的账号信息、项目设置、IAM 或资源概览页获取。
CLOUD_ACCOUNT_ID=
CLOUD_PROJECT_ID=
CLOUD_API_KEY=
CLOUD_API_SECRET=
CLOUD_REGION=

# ---------------------------------------------------------------------------
# Git / Release / 包发布凭据
# ---------------------------------------------------------------------------
# Git 平台访问令牌，用于 ai-git2 推送分支、创建 tag、创建 release 或访问私有仓库。
# GitHub：Settings -> Developer settings -> Personal access tokens。建议最小权限：repo / workflow / packages 按需开启。
# GitLab：User Settings -> Access Tokens。建议只给目标项目需要的 read_repository / write_repository / api 权限。
GIT_TOKEN=
GITHUB_TOKEN=
GITLAB_TOKEN=

# 包仓库发布或读取私有包用的 Token。npm 可在 npmjs.com Access Tokens 或企业仓库后台生成。
PACKAGE_REGISTRY_TOKEN=
NPM_TOKEN=

# ---------------------------------------------------------------------------
# Cloudflare
# ---------------------------------------------------------------------------
# API Token：Cloudflare Dashboard -> My Profile -> API Tokens -> Create Token。
# Pages/Workers/R2/D1/DNS 按需授予最小权限，不建议使用 Global API Key。
CLOUDFLARE_API_TOKEN=

# Account ID：Cloudflare Dashboard 右侧栏或账户首页可见。
CLOUDFLARE_ACCOUNT_ID=

# Zone ID：只有需要管理 DNS、证书、缓存或域名记录时填写；在具体域名概览页右侧栏可见。
CLOUDFLARE_ZONE_ID=

# ---------------------------------------------------------------------------
# Vercel
# ---------------------------------------------------------------------------
# Token：Vercel Account Settings -> Tokens 创建，建议只用于目标团队/项目。
VERCEL_TOKEN=

# Team ID / Org ID：团队设置或项目接口中可见；个人账号项目可留空。
VERCEL_TEAM_ID=

# Project ID：Vercel 项目 Settings -> General 中可见。
VERCEL_PROJECT_ID=

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
# AWS Access Key：IAM -> Users -> Security credentials 创建访问密钥。
# 建议创建专用 IAM 用户或角色，只授予 Lambda / S3 / CloudFront / ECS / Amplify 等实际需要的最小权限。
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 默认地域，例如 us-east-1 / ap-southeast-1。以部署目标资源所在地域为准。
AWS_REGION=

# 临时凭据才需要填写 Session Token；长期 Access Key 留空。
AWS_SESSION_TOKEN=

# ---------------------------------------------------------------------------
# Google Cloud / Firebase
# ---------------------------------------------------------------------------
# 项目 ID：Google Cloud Console 项目选择器里可见。
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=

# 服务账号 JSON 路径：在 IAM & Admin -> Service Accounts 创建 key 后，把 json 文件放在本机安全位置，并把绝对路径写这里。
# 不建议把 json 文件放进仓库。
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase 部署 Token：可用 firebase login:ci 生成；优先考虑服务账号方式。
FIREBASE_TOKEN=

# ---------------------------------------------------------------------------
# Azure
# ---------------------------------------------------------------------------
# 使用服务主体登录：az ad sp create-for-rbac --name <name> --role Contributor --scopes /subscriptions/<subscription-id>
# 命令输出里的 appId/password/tenant 分别对应下面的 CLIENT_ID / CLIENT_SECRET / TENANT_ID。
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ---------------------------------------------------------------------------
# Tencent Cloud
# ---------------------------------------------------------------------------
# 访问密钥：腾讯云控制台 -> 访问管理 CAM -> API 密钥管理。
# 建议创建子用户并只授予 SCF / API Gateway / CloudBase / COS 等实际需要的权限。
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=

# ---------------------------------------------------------------------------
# Alibaba Cloud
# ---------------------------------------------------------------------------
# AccessKey：阿里云控制台 -> RAM 访问控制 -> 用户 -> AccessKey。
# 建议使用 RAM 用户，按需授予 FC / SAE / ECS / OSS / CDN 等最小权限。
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION=

# 部分阿里云 CLI / SDK 也识别 ALIYUN_* 命名；需要兼容旧脚本时可同步填写。
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=

# ---------------------------------------------------------------------------
# Huawei Cloud
# ---------------------------------------------------------------------------
# AK/SK：华为云控制台 -> 我的凭证 -> 访问密钥。
HUAWEI_CLOUD_ACCESS_KEY_ID=
HUAWEI_CLOUD_SECRET_ACCESS_KEY=
HUAWEI_CLOUD_REGION=

# Project ID：我的凭证 -> API 凭证，可按地域查看。
HUAWEI_CLOUD_PROJECT_ID=

# ---------------------------------------------------------------------------
# Oracle Cloud Infrastructure
# ---------------------------------------------------------------------------
# OCI 配置来自用户 API Key。可在 OCI Console -> Profile -> API Keys 添加公钥后获取 tenancy/user/fingerprint。
# 私钥可用 openssl genrsa -out ~/.oci/oci_api_key.pem 2048 生成，并把公钥上传到 OCI。
OCI_TENANCY=
OCI_USER=
OCI_FINGERPRINT=
OCI_KEY_FILE=
OCI_REGION=

# ---------------------------------------------------------------------------
# 应用运行密钥
# ---------------------------------------------------------------------------
# 应用级随机密钥。可用以下方式生成：
# - openssl rand -hex 32
# - node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=
JWT_SECRET=

# 数据库连接串。格式取决于数据库类型，例如：
# - PostgreSQL: postgres://user:password@host:5432/dbname
# - MySQL: mysql://user:password@host:3306/dbname
# - SQLite: file:./data/app.db
DATABASE_URL=

# ---------------------------------------------------------------------------
# 初始管理员账号
# ---------------------------------------------------------------------------
# 仅用于初始化或种子脚本。生产环境请改成团队真实管理员邮箱，并用强随机密码。
# 邮箱示例：admin@ai-unions.com。
# 密码可用 openssl rand -base64 24 生成；不要使用 Admin123456! 这类示例弱密码。
DEFAULT_ADMIN_EMAIL=admin@ai-unions.com
DEFAULT_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# 第三方集成
# ---------------------------------------------------------------------------
# OpenAI API Key：OpenAI Platform -> API keys 创建；建议按项目单独创建并限制使用范围。
OPENAI_API_KEY=

# Sentry DSN：Sentry 项目 Settings -> Client Keys (DSN)。
SENTRY_DSN=

# Slack Incoming Webhook：Slack App -> Incoming Webhooks 创建，通常用于部署通知。
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# 其他团队自定义密钥
# ---------------------------------------------------------------------------
# 如果项目需要更多密钥，可以追加在本节；命名建议使用大写蛇形命名，例如 PAYMENT_PROVIDER_API_KEY。
