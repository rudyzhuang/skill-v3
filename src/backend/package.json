{
  "name": "@dash-std4/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 8787",
    "build": "wrangler deploy --dry-run --outdir=dist",
