{
  "$id": "https://skill-v3.local/schemas/design-review-output.v1.schema.json",
  "title": "ai-design3 design-review structured merge payload (per feature or batch)",
  "description": "Merged into stages.design_review.outputs by merge-design-review.cjs. See prompts/design-review.md.",
  "type": "object",
  "required": ["outputs", "gaps"],
  "properties": {
    "feature_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/featurePayload" }
    },
    "outputs": {
      "type": "object",
      "required": ["decision"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["passed", "failed", "pending", "needs_design_fix", "needs_contract_fix"]
        },
        "alignment_summary": { "type": "string" }
      },
      "additionalProperties": true
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    }
  },
  "$defs": {
    "gap": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "feature_id": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string", "enum": ["blocking", "warning", "info"] },
        "blocking": { "type": "boolean" },
        "message": { "type": "string", "minLength": 1 },
        "suggested_action": { "type": "string" }
      },
      "additionalProperties": true
    },
    "featurePayload": {
      "type": "object",
      "required": ["feature_id", "outputs", "gaps"],
      "properties": {
        "feature_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "outputs": {
          "type": "object",
          "required": ["decision"],
          "properties": {
            "decision": {
              "type": "string",
              "enum": ["passed", "failed", "pending", "needs_design_fix", "needs_contract_fix"]
            },
            "alignment_summary": { "type": "string" }
          },
          "additionalProperties": true
        },
        "gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
