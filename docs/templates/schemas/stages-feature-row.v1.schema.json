{
  "$id": "https://skill-v3.local/schemas/stages-feature-row.v1.schema.json",
  "title": "Skill V3 stages.json feature row",
  "description": "One element of stages.<stage>.features[] in .pipeline/stages.json. See docs/input-spec.md §7.1.1.",
  "type": "object",
  "required": ["feature_id", "status"],
  "additionalProperties": true,
  "properties": {
    "feature_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "status": {
      "type": "string",
      "enum": ["not_started", "running", "completed", "failed", "skipped"]
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "message": {
      "type": "string"
    },
    "test_result": {
      "type": "string",
      "description": "test stage only: passed | failed | failed_max_attempts | …"
    },
    "attempts": {
      "type": "integer",
      "minimum": 0
    },
    "last_exit": {
      "type": "integer"
    },
    "fail_reason": {
      "type": ["string", "null"]
    },
    "passed": {
      "type": "boolean",
      "description": "test stage convenience mirror of test_result"
    },
    "last_heartbeat_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "由 stage 脚本在 agent/tool 执行期间每 30 s 写入，用于活跃性检测与精确计时"
    },
    "elapsed_ms": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "最后一次心跳时累计运行毫秒数（基于 started_at 计算）；ai-dash3 优先动态计算，此字段可用于离线分析"
    }
  }
}
