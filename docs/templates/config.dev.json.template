{
  "_schema": {
    "name": "skill-v3-project-config",
    "version": 1,
    "environment": "dev"
  },
  "project": {
    "name": "",
    "project_id": "",
    "root_path": "",
    "default_client_targets": []
  },
  "git": {
    "remote": "origin",
    "default_branch": "main",
    "working_branch_prefix": "ai",
    "allow_push": false
  },
  "pipeline": {
    "_doc": "Orchestration flags consumed by ai-auto3 autorun.cjs (dev config only). See docs/spec/publish3.md §5.1.1 and docs/spec/auto3.md §5.1.",
    "autorun": {
      "_doc": "When allow_destructive_deploy is false, autorun.cjs must not spawn ai-publish-dev3 deploy; missing key is treated as false (additive default). deploy.enabled alone is not sufficient. feature_group_max_parallel caps concurrent ai-code3 group processes in codegen..code-review (see docs/spec/auto3.md §5.7.4); missing defaults to 3.",
      "allow_destructive_deploy": false,
      "feature_group_max_parallel": 3
    }
  },
  "build": {
    "package_manager": "auto",
    "commands": {
      "install": "",
      "typecheck": "",
      "test": "",
      "build": "",
      "test_max_fix_attempts": 3
    },
    "test_level_gate": {
      "_doc": "Optional test-level gate consumed by ai-code3 test.cjs. mode: off|warn|enforce. Required levels are resolved from contract test_spec.required_test_levels first, then fallback_required_test_levels.",
      "mode": "warn",
      "fallback_required_test_levels": []
    },
    "artifacts_dir": "dist",
    "client_targets": {}
  },
  "timeouts": {
    "_doc": "Timeouts for autorun.cjs and per-stage skills. Unit: seconds. See input-spec.md §6.1.",
    "autorun_total_s": 7200,
    "stages": {
      "prd_s": 600,
      "prd_review_s": 600,
      "design_s": 600,
      "contract_s": 600,
      "design_review_s": 600,
      "codegen_s": 1800,
      "typecheck_s": 600,
      "test_s": 1800,
      "code_review_s": 600,
      "merge_push_s": 300,
      "build_s": 1800,
      "deploy_s": 1800,
      "smoke_s": 300,
      "ui_e2e_s": 3600,
      "report_s": 600
    },
    "subcommand": {
      "default_s": 600,
      "graceful_shutdown_s": 5,
      "heartbeat_interval_s": 30
    }
  },
  "deploy": {
    "enabled": false,
    "environment": "dev",
    "provider": "manual",
    "region": "",
    "project_or_account": "",
    "services": [
      {
        "client_target": "website",
        "sub_platform": "default",
        "service_name": "",
        "resource_type": "",
        "runtime": "",
        "region": "",
        "domain": "",
        "healthcheck_path": "/",
        "create_if_missing": false,
        "resource_config": {}
      }
    ]
  },
  "smoke": {
    "enabled": true,
    "base_url": "",
    "safe_only": true,
    "checks": [
      {
        "name": "homepage",
        "method": "GET",
        "path": "/",
        "expected_status": 200
      }
    ]
  },
  "ui_e2e": {
    "_doc": "UI end-to-end (Browser MCP for website/admin; Dart MCP + flutter integration_test for mobile). Consumed by ai-e2e3. See docs/spec/e2e3.md.",
    "enabled": false,
    "require_smoke_passed": true,
    "web": {
      "website": { "base_url_from": "deploy.services.website.url" },
      "admin": { "base_url_from": "deploy.services.admin.url" }
    },
    "mobile": {
      "sub_platforms": [],
      "android": {
        "device_id": "",
        "emulator_id": "",
        "auto_launch_emulator": true,
        "install_before_test": true,
        "bundle_id": ""
      },
      "ios": {
        "simulator": "",
        "device_id": "",
        "auto_launch_simulator": true,
        "install_before_test": true,
        "bundle_id": ""
      },
      "commands": {
        "boot_wait_s": 90,
        "smoke_run_s": 35
      }
    },
    "commands": {
      "ui_test_max_fix_attempts": 3
    },
    "stub_mode": false
  },
  "security": {
    "env_file_path": "docs/config.env",
    "forbidden_json_key_patterns": [
      "secret",
      "token",
      "api_key",
      "apikey",
      "password",
      "credential",
      "private_key"
    ]
  },
  "metadata": {
    "created_by": "ai-prd3",
    "created_at": null,
    "updated_at": null
  }
}
