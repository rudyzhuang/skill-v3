{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "config.json.schema.json",
  "title": "config.dev.json / config.release.json",
  "type": "object",
  "required": ["pipeline", "git", "build", "deploy", "smoke", "ui_e2e", "timeouts"],
  "properties": {
    "pipeline": {
      "type": "object",
      "required": ["autorun"],
      "properties": {
        "autorun": {
          "type": "object",
          "required": ["allow_destructive_deploy", "feature_max_parallel"],
          "properties": {
            "allow_destructive_deploy": { "type": "boolean" },
            "feature_max_parallel":    { "type": "integer", "minimum": 1, "maximum": 16, "default": 3 },
            "build_max_parallel":      { "type": "integer", "minimum": 1, "maximum": 16 }
          }
        },
        "stages": {
          "type": "object",
          "properties": {
            "build": {
              "type": "object",
              "properties": {
                "client_max_parallel": { "type": "integer", "minimum": 1, "maximum": 16 }
              }
            },
            "design": {
              "type": "object",
              "properties": {
                "feature_max_parallel": { "type": "integer", "minimum": 1, "maximum": 16 }
              }
            },
            "design_review": {
              "type": "object",
              "properties": {
                "feature_max_parallel": { "type": "integer", "minimum": 1, "maximum": 16 }
              }
            },
            "codegen": {
              "type": "object",
              "properties": {
                "feature_max_parallel": { "type": "integer", "minimum": 1, "maximum": 16 }
              }
            },
            "deploy": {
              "type": "object",
              "properties": {
                "agent_fix_max_attempts": { "type": "integer", "minimum": 0, "maximum": 5, "default": 2 },
                "deploy_retry_max": { "type": "integer", "minimum": 0, "maximum": 5, "default": 1 },
                "fail_fast": { "type": "boolean", "default": true }
              }
            },
            "ui_e2e": {
              "type": "object",
              "properties": {
                "scenario_max_parallel": { "type": "integer", "minimum": 1, "maximum": 16 },
                "triage_max_attempts": { "type": "integer", "minimum": 0, "maximum": 5, "default": 2 },
                "prompt_fix_max_attempts": { "type": "integer", "minimum": 0, "maximum": 3, "default": 1 },
                "fail_fast": { "type": "boolean", "default": false }
              }
            }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "required": ["remote", "default_branch", "auto_commit"],
      "properties": {
        "remote":         { "type": "string", "minLength": 1 },
        "default_branch": { "type": "string", "minLength": 1 },
        "auto_commit":    { "type": "boolean" }
      }
    },
    "build": {
      "type": "object",
      "required": ["commands"],
      "properties": {
        "artifacts_dir": { "type": "string", "default": "dist" },
        "install_before_build": { "type": "boolean", "default": true },
        "fail_fast": { "type": "boolean", "default": false },
        "force_backend_build": { "type": "boolean", "default": false },
        "client_targets": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string" }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "skip": { "type": "boolean" },
                  "cwd": { "type": "string" },
                  "build": { "type": "string" },
                  "artifact_path": { "type": "string" },
                  "artifact_globs": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "sub_platforms": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id"],
                      "properties": {
                        "id": { "type": "string" },
                        "build": { "type": "string" },
                        "artifact_path": { "type": "string" },
                        "artifact_globs": {
                          "type": "array",
                          "items": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        "commands": {
          "type": "object",
          "properties": {
            "build": { "type": "string" },
            "install": { "type": "string" }
          },
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "deploy": {
      "type": "object",
      "required": ["enabled", "provider", "services"],
      "properties": {
        "enabled":  { "type": "boolean" },
        "provider": { "type": "string", "enum": ["cloudflare", "aws", "gcp", "manual"] },
        "domain":   { "type": "string" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "client_target", "type"],
            "properties": {
              "name":          { "type": "string", "minLength": 1 },
              "client_target": { "type": "string" },
              "sub_platform":  { "type": "string" },
              "type":          { "type": "string", "enum": ["pages", "workers"] },
              "domain":        { "type": "string" },
              "url":           { "type": "string" },
              "artifact_ref":  { "type": "string" }
            }
          }
        }
      }
    },
    "smoke": {
      "type": "object",
      "required": ["checks"],
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["method", "expected_status"],
            "properties": {
              "url":             { "type": "string" },
              "path":            { "type": "string" },
              "method":          { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD"] },
              "expected_status": { "type": "integer", "minimum": 100, "maximum": 599 },
              "body_contains":   { "type": ["string", "null"] },
              "safe":            { "type": "boolean" },
              "client_targets": {
                "type": "array",
                "items": { "type": "string" }
              },
              "scope": {
                "type": "string",
                "enum": ["codegen", "deploy", "both"],
                "default": "both"
              }
            }
          }
        },
        "codegen": {
          "type": "object",
          "properties": {
            "enabled":   { "type": "boolean", "default": true },
            "base_url":  { "type": "string" },
            "timeout_s": { "type": "integer", "minimum": 1, "default": 60 }
          }
        },
        "deploy": {
          "type": "object",
          "properties": {
            "enabled":   { "type": "boolean", "default": true },
            "timeout_s": { "type": "integer", "minimum": 1, "default": 120 }
          }
        }
      }
    },
    "ui_e2e": {
      "type": "object",
      "required": ["enabled", "require_deploy_smoke_passed"],
      "properties": {
        "enabled":                      { "type": "boolean" },
        "require_deploy_smoke_passed":  { "type": "boolean", "default": true },
        "strict_mobile":                { "type": "boolean", "default": false },
        "require_smoke_passed": {
          "type": "boolean",
          "description": "已废弃：请用 require_deploy_smoke_passed（deploy 内联 smoke）"
        },
        "web": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "base_url_from": { "type": "string" }
            }
          }
        },
        "mobile": {
          "type": "object",
          "properties": {
            "bundle_id": { "type": "string" },
            "device": { "type": "string" },
            "auto_launch_emulator": { "type": "boolean", "default": true }
          }
        },
        "commands": {
          "type": "object",
          "properties": {
            "scenario_max_fix_attempts": { "type": "integer", "minimum": 0, "maximum": 5, "default": 2 },
            "ui_test_max_fix_attempts": {
              "type": "integer",
              "minimum": 1,
              "description": "已废弃：请用 scenario_max_fix_attempts"
            }
          }
        }
      }
    },
    "timeouts": {
      "type": "object",
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "object",
          "properties": {
            "design_s":  { "type": "integer", "minimum": 1 },
            "design_review_s": { "type": "integer", "minimum": 1 },
            "create_ui_scenarios_s": { "type": "integer", "minimum": 1 },
            "build_s":   { "type": "integer", "minimum": 1 },
            "codegen_s": { "type": "integer", "minimum": 1 },
            "deploy_s":  { "type": "integer", "minimum": 1 },
            "ui_e2e_s":  { "type": "integer", "minimum": 1 },
            "ui_e2e_scenario_s": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
