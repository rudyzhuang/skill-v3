{
  "$id": "https://skill-v3.local/schemas/design-spec.v3.schema.json",
  "title": "DesignSpecFileV3",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "feature_id",
    "client_target",
    "status"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "minLength": 1
    },
    "client_target": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_contract",
        "approved",
        "superseded"
      ]
    },
    "spec_path": {
      "type": "string"
    },
    "file_plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "new_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "modify_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reuse_existing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "api_outline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "data_outline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shared_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "library_decisions": {
      "type": "object",
      "additionalProperties": true,
      "description": "由 lib-research 子命令回写；含 ref 指向 docs/designs/<feature_id>.lib-research.json"
    },
    "style_scan_ref": {
      "type": "string",
      "description": "可选：指向 docs/designs/<feature_id>.style-scan.json"
    }
  }
}
